{
  "name": "@repo/db",
  "version": "1.0.0",
  "main": "./src/index.ts",
  "exports": {
    "./client": "./src/index.ts"
  },
  "scripts": {
    "build": "prisma generate",
    "db:generate": "node -r ./load-env.cjs ./node_modules/prisma/build/index.js generate",
    "db:push": "node -r ./load-env.cjs ./node_modules/prisma/build/index.js db push",
    "db:migrate": "node -r ./load-env.cjs ./node_modules/prisma/build/index.js migrate dev",
    "db:deploy": "node -r ./load-env.cjs ./node_modules/prisma/build/index.js migrate deploy",
    "db:studio": "node -r ./load-env.cjs ./node_modules/prisma/build/index.js studio"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*"
  },
  "keywords": [
    "database",
    "prisma"
  ],
  "author": "Ashish Mahajan",
  "description": "Database package for Scribbix",
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "dotenv": "17.4.2",
    "prisma": "^6.2.1"
  }
}
